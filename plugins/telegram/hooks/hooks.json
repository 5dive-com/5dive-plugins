{
  "description": "5dive telegram plugin lifecycle hooks — block invisible pickers in telegram-paired sessions, nudge the agent when it goes silent on Telegram, catch 'agent talked to the transcript instead of replying' misses, and DM-on-StopFailure with auto-resume after usage-limit hits.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pretool-question.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/silence-watchdog.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-reply-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stopfailure-notify.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
